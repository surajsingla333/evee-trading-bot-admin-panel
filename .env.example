# test = mock data · development | production = live Admin API
VITE_APP_ENV=development

# Leave empty to call the API through the same-origin proxy (avoids CORS).
# Set an absolute URL only if the API itself allows your origin via CORS.
VITE_API_URL=
VITE_API_TOKEN=your_admin_api_token

# Proxy target used by vite dev server and server.js
API_PROXY_TARGET=https://evee-trading-bot-production.up.railway.app

# Optional Solana RPC for Phantom payouts (public mainnet RPC often returns 403).
# Use a Helius / QuickNode / Alchemy HTTPS URL. Falls back to publicnode → ankr.
# VITE_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
